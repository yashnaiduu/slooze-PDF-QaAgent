# LLM Configuration
LLM_PROVIDER=openai            # openai | anthropic | ollama | openai_compatible
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Provider API Keys
OPENAI_API_KEY=
OPENAI_BASE_URL=               # only for openai_compatible provider
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_PROVIDER=sentence_transformers

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Vector Store
VECTOR_STORE_TYPE=faiss         # faiss | chroma
TOP_K=5

# Application
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
